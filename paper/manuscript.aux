\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515 and iYS1720), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard.}}{11}{figure.1}\protected@file@percent }
\newlabel{fig:arch}{{1}{11}{\textbf {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515 and iYS1720), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {FBA gene knockout simulation in \textit  {E. coli} iML1515.} Bar height represents growth ratio (knockout/wild-type). Values below the dashed line (0.01) indicate lethal knockouts. Color indicates organ-specific toxicity risk assessment. Of 19 mapped genes, 18 (94.7\%) showed lethal phenotypes, confirming their essentiality for bacterial survival.}}{12}{figure.2}\protected@file@percent }
\newlabel{fig:fba}{{2}{12}{\textbf {FBA gene knockout simulation in \textit {E. coli} iML1515.} Bar height represents growth ratio (knockout/wild-type). Values below the dashed line (0.01) indicate lethal knockouts. Color indicates organ-specific toxicity risk assessment. Of 19 mapped genes, 18 (94.7\%) showed lethal phenotypes, confirming their essentiality for bacterial survival}{figure.2}{}}
\citation{arora2026}
\citation{arora2026}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Drug combination potency-toxicity landscape.} Each point represents one of 91 pairwise target combinations evaluated by double-gene knockout FBA. Gold stars indicate the 6 Pareto-optimal combinations. Green shaded region marks the ideal Q1 quadrant (high potency, low toxicity). Dashed lines indicate median thresholds. All Pareto-optimal combinations involve accA (fatty acid synthesis) paired with LPS synthesis pathway targets, suggesting complementary metabolic disruption as an effective combination strategy.}}{13}{figure.3}\protected@file@percent }
\newlabel{fig:landscape}{{3}{13}{\textbf {Drug combination potency-toxicity landscape.} Each point represents one of 91 pairwise target combinations evaluated by double-gene knockout FBA. Gold stars indicate the 6 Pareto-optimal combinations. Green shaded region marks the ideal Q1 quadrant (high potency, low toxicity). Dashed lines indicate median thresholds. All Pareto-optimal combinations involve accA (fatty acid synthesis) paired with LPS synthesis pathway targets, suggesting complementary metabolic disruption as an effective combination strategy}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN, showing potency (blue) and toxicity (red) contributions for each metabolic subsystem. Glycerophospholipid metabolism and purine/pyrimidine biosynthesis show the highest potency influence. (B) Feature knock-off analysis showing the percentage change in predictions when each subsystem's features are zeroed out. Nucleotide salvage pathway shows selective influence on toxicity predictions, consistent with \citet  {arora2026}.}}{14}{figure.4}\protected@file@percent }
\newlabel{fig:pathways}{{4}{14}{\textbf {Metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN, showing potency (blue) and toxicity (red) contributions for each metabolic subsystem. Glycerophospholipid metabolism and purine/pyrimidine biosynthesis show the highest potency influence. (B) Feature knock-off analysis showing the percentage change in predictions when each subsystem's features are zeroed out. Nucleotide salvage pathway shows selective influence on toxicity predictions, consistent with \citet {arora2026}}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Bacterial-human sequence identity for top AMR targets.} Horizontal bars show approximate sequence identity (\%) between each bacterial drug target and its closest human homolog. Orange dashed line (25\%) indicates the moderate risk threshold; red dashed line (40\%) indicates the high risk threshold. All 20 analyzed targets fall below 12.2\% identity, with the majority showing no detectable human homolog (0\%), indicating excellent selectivity profiles for drug development.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:selectivity}{{5}{14}{\textbf {Bacterial-human sequence identity for top AMR targets.} Horizontal bars show approximate sequence identity (\%) between each bacterial drug target and its closest human homolog. Orange dashed line (25\%) indicates the moderate risk threshold; red dashed line (40\%) indicates the high risk threshold. All 20 analyzed targets fall below 12.2\% identity, with the majority showing no detectable human homolog (0\%), indicating excellent selectivity profiles for drug development}{figure.5}{}}
