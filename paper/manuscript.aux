\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515, iYS1720, and iYL1228), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard.}}{13}{figure.1}\protected@file@percent }
\newlabel{fig:arch}{{1}{13}{\textbf {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515, iYS1720, and iYL1228), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Essential gene FBA analysis across three ESKAPE models (mapped genes only).} Heatmap shows FBA results for \textit  {E. coli} (iML1515), \textit  {S. aureus} (iYS1720), and \textit  {K. pneumoniae} (iYL1228). Red = lethal knockout, orange = growth-reducing, gray = not mapped in this model. Only genes mapped in at least one model are shown (20 unmapped genes listed in Supplementary Table S1). Cross-species consistency: lpxA--D, murA--F, accA, and fabI are lethal in all models where mapped. Note species-specific differences: fabH is lethal in \textit  {E. coli} but growth-reducing in \textit  {S. aureus}; folA/folP are lethal in \textit  {E. coli} but not mapped in \textit  {S. aureus}. Symbols: \raisebox  {-1pt}{\small  $\blacklozenge $} = has existing drug; \raisebox  {-1pt}{\small  $\bigstar $} = novel target.}}{14}{figure.2}\protected@file@percent }
\newlabel{fig:fba}{{2}{14}{\textbf {Essential gene FBA analysis across three ESKAPE models (mapped genes only).} Heatmap shows FBA results for \textit {E. coli} (iML1515), \textit {S. aureus} (iYS1720), and \textit {K. pneumoniae} (iYL1228). Red = lethal knockout, orange = growth-reducing, gray = not mapped in this model. Only genes mapped in at least one model are shown (20 unmapped genes listed in Supplementary Table S1). Cross-species consistency: lpxA--D, murA--F, accA, and fabI are lethal in all models where mapped. Note species-specific differences: fabH is lethal in \textit {E. coli} but growth-reducing in \textit {S. aureus}; folA/folP are lethal in \textit {E. coli} but not mapped in \textit {S. aureus}. Symbols: \raisebox {-1pt}{\small $\blacklozenge $} = has existing drug; \raisebox {-1pt}{\small $\bigstar $} = novel target}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {NLP extraction quality comparison.} (A) Keyword NLP: red = section header noise (RESULTS, METHODS), orange = biological terms that are not genes (LPS, CRISPR, ROS), blue = correctly extracted genes. Majority of top extractions are non-gene artifacts. (B) LLM NLP (gemma4:e4b): blue = AMR targets, green = pruritus targets. Processing 393 AMR + 521 pruritus articles, LLM achieves 92\% gene precision (UniProt-validated) with 50\% article extraction rate. No section-header noise detected.}}{14}{figure.3}\protected@file@percent }
\newlabel{fig:nlp}{{3}{14}{\textbf {NLP extraction quality comparison.} (A) Keyword NLP: red = section header noise (RESULTS, METHODS), orange = biological terms that are not genes (LPS, CRISPR, ROS), blue = correctly extracted genes. Majority of top extractions are non-gene artifacts. (B) LLM NLP (gemma4:e4b): blue = AMR targets, green = pruritus targets. Processing 393 AMR + 521 pruritus articles, LLM achieves 92\% gene precision (UniProt-validated) with 50\% article extraction rate. No section-header noise detected}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Target composite score distribution.} AMR targets scored across 6 evidence dimensions. Vertical dashed lines indicate tier boundaries. Tier 1 targets ($>$0.7) are prioritized for experimental validation. Key targets (lpxC, lpxA, bamA) are annotated. Rankings are sensitive to scoring weight selection (see Sensitivity Analysis in text).}}{15}{figure.4}\protected@file@percent }
\newlabel{fig:scores}{{4}{15}{\textbf {Target composite score distribution.} AMR targets scored across 6 evidence dimensions. Vertical dashed lines indicate tier boundaries. Tier 1 targets ($>$0.7) are prioritized for experimental validation. Key targets (lpxC, lpxA, bamA) are annotated. Rankings are sensitive to scoring weight selection (see Sensitivity Analysis in text)}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Exploratory metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN. Note the relatively flat potency weights (0.07--0.10 range), suggesting limited discriminative learning due to circular FBA-to-FBA dependency. (B) Feature knock-off analysis. Results should be interpreted as hypothesis-generating: nucleotide salvage removal paradoxically increases potency, and ``Unassigned'' reactions show unexpectedly large toxicity impact, indicating partial reliance on biologically uncharacterized features.}}{15}{figure.5}\protected@file@percent }
\newlabel{fig:pathways}{{5}{15}{\textbf {Exploratory metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN. Note the relatively flat potency weights (0.07--0.10 range), suggesting limited discriminative learning due to circular FBA-to-FBA dependency. (B) Feature knock-off analysis. Results should be interpreted as hypothesis-generating: nucleotide salvage removal paradoxically increases potency, and ``Unassigned'' reactions show unexpectedly large toxicity impact, indicating partial reliance on biologically uncharacterized features}{figure.5}{}}
\bibstyle{unsrtnat}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Bacterial-human protein homology (literature-curated audit).} Dot plot shows sequence identity (\%) to closest human homolog for 21 AMR targets. Green circles = no detectable homolog (11 targets); yellow/orange = low/moderate identity; red X = high risk. folA shows 30\% identity to human DHFR2, consistent with known trimethoprim cross-reactivity. accA (22\%, ACACA) and gyrA (18\%, TOP2A) also require selectivity engineering. Orange and red dashed lines indicate 25\% and 40\% risk thresholds.}}{16}{figure.6}\protected@file@percent }
\newlabel{fig:selectivity}{{6}{16}{\textbf {Bacterial-human protein homology (literature-curated audit).} Dot plot shows sequence identity (\%) to closest human homolog for 21 AMR targets. Green circles = no detectable homolog (11 targets); yellow/orange = low/moderate identity; red X = high risk. folA shows 30\% identity to human DHFR2, consistent with known trimethoprim cross-reactivity. accA (22\%, ACACA) and gyrA (18\%, TOP2A) also require selectivity engineering. Orange and red dashed lines indicate 25\% and 40\% risk thresholds}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Top 10 AMR Drug Target Candidates}, ranked by composite score. FBA status: Tier A = lethal knockout confirmed; Tier B = not mapped in GEM. Homolog data from literature-curated audit. Ties broken by alphabetical order within same score. $^\dagger $Rankings sensitive to weight selection ($\pm $10\% perturbation range: 0.053--0.072).}}{16}{table.1}\protected@file@percent }
\newlabel{tab:targets}{{1}{16}{\textbf {Top 10 AMR Drug Target Candidates}, ranked by composite score. FBA status: Tier A = lethal knockout confirmed; Tier B = not mapped in GEM. Homolog data from literature-curated audit. Ties broken by alphabetical order within same score. $^\dagger $Rankings sensitive to weight selection ($\pm $10\% perturbation range: 0.053--0.072)}{table.1}{}}
