\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515, iYS1720, and iYL1228), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard.}}{12}{figure.1}\protected@file@percent }
\newlabel{fig:arch}{{1}{12}{\textbf {Platform architecture.} Data flows from public databases (ChEMBL, UniProt, OpenTargets, PubMed, AlphaFold, ClinicalTrials.gov, FAERS) through knowledge graph construction (Neo4j, 2,224 nodes), metabolic modeling (COBRApy FBA on iML1515, iYS1720, and iYL1228), LLM-powered NLP (Ollama/Claude), and structural analysis (AlphaFold) into a CALMA-inspired analysis engine. Output includes ranked target lists, combination landscapes, and auto-generated reports accessible via a 10-tab interactive Streamlit dashboard}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Essential gene FBA analysis across ESKAPE models.} Heatmap shows FBA results for \textit  {E. coli} (iML1515) and \textit  {S. aureus} (iYS1720). Red = lethal knockout, orange = growth-reducing, gray = not mapped in model. Cross-species consistency: lpxA--D, murA--F, accA, and fabI are lethal in all models where mapped. \textit  {K. pneumoniae} (iYL1228) confirmed 12/16 mapped genes as lethal (Supplementary Table S1).}}{13}{figure.2}\protected@file@percent }
\newlabel{fig:fba}{{2}{13}{\textbf {Essential gene FBA analysis across ESKAPE models.} Heatmap shows FBA results for \textit {E. coli} (iML1515) and \textit {S. aureus} (iYS1720). Red = lethal knockout, orange = growth-reducing, gray = not mapped in model. Cross-species consistency: lpxA--D, murA--F, accA, and fabI are lethal in all models where mapped. \textit {K. pneumoniae} (iYL1228) confirmed 12/16 mapped genes as lethal (Supplementary Table S1)}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {NLP extraction quality comparison.} (A) Traditional keyword-based NLP extracts non-gene noise artifacts (red bars: ``RESULTS'', ``METHODS'', ``AREAS'') as top ``genes''. (B) LLM-powered NLP (gemma4:e4b) correctly identifies real genes (FtsZ, IL31, LpxC) with 92\% precision validated against UniProt. 914 PubMed articles processed.}}{13}{figure.3}\protected@file@percent }
\newlabel{fig:nlp}{{3}{13}{\textbf {NLP extraction quality comparison.} (A) Traditional keyword-based NLP extracts non-gene noise artifacts (red bars: ``RESULTS'', ``METHODS'', ``AREAS'') as top ``genes''. (B) LLM-powered NLP (gemma4:e4b) correctly identifies real genes (FtsZ, IL31, LpxC) with 92\% precision validated against UniProt. 914 PubMed articles processed}{figure.3}{}}
\citation{arora2026}
\citation{arora2026}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Target composite score distribution.} AMR targets scored across 6 evidence dimensions. Vertical dashed lines indicate tier boundaries. Tier 1 targets ($>$0.7) are prioritized for experimental validation. Key targets (lpxC, lpxA, bamA) are annotated. Rankings are sensitive to scoring weight selection (see Sensitivity Analysis in text).}}{14}{figure.4}\protected@file@percent }
\newlabel{fig:scores}{{4}{14}{\textbf {Target composite score distribution.} AMR targets scored across 6 evidence dimensions. Vertical dashed lines indicate tier boundaries. Tier 1 targets ($>$0.7) are prioritized for experimental validation. Key targets (lpxC, lpxA, bamA) are annotated. Rankings are sensitive to scoring weight selection (see Sensitivity Analysis in text)}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN, showing potency (blue) and toxicity (red) contributions for each metabolic subsystem. Glycerophospholipid metabolism and purine/pyrimidine biosynthesis show the highest potency influence. (B) Feature knock-off analysis showing the percentage change in predictions when each subsystem's features are zeroed out. Nucleotide salvage pathway shows selective influence on toxicity predictions, consistent with \citet  [in press]{arora2026}.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:pathways}{{5}{14}{\textbf {Metabolic pathway importance analysis.} (A) Subsystem weights from the metabolism-informed ANN, showing potency (blue) and toxicity (red) contributions for each metabolic subsystem. Glycerophospholipid metabolism and purine/pyrimidine biosynthesis show the highest potency influence. (B) Feature knock-off analysis showing the percentage change in predictions when each subsystem's features are zeroed out. Nucleotide salvage pathway shows selective influence on toxicity predictions, consistent with \citet [in press]{arora2026}}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Bacterial-human protein homology (literature-curated audit).} Dot plot shows sequence identity (\%) to closest human homolog for 21 AMR targets. Green circles = no detectable homolog (11 targets); yellow/orange = low/moderate identity; red X = high risk. folA shows 30\% identity to human DHFR2, consistent with known trimethoprim cross-reactivity. accA (22\%, ACACA) and gyrA (18\%, TOP2A) also require selectivity engineering. Orange and red dashed lines indicate 25\% and 40\% risk thresholds.}}{15}{figure.6}\protected@file@percent }
\newlabel{fig:selectivity}{{6}{15}{\textbf {Bacterial-human protein homology (literature-curated audit).} Dot plot shows sequence identity (\%) to closest human homolog for 21 AMR targets. Green circles = no detectable homolog (11 targets); yellow/orange = low/moderate identity; red X = high risk. folA shows 30\% identity to human DHFR2, consistent with known trimethoprim cross-reactivity. accA (22\%, ACACA) and gyrA (18\%, TOP2A) also require selectivity engineering. Orange and red dashed lines indicate 25\% and 40\% risk thresholds}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Top 10 AMR Drug Target Candidates}, ranked by composite score. FBA status indicates Tier A (lethal knockout confirmed) or Tier B (not mapped in GEM). Human homolog column reflects literature-curated audit. $^\dagger $Rankings are sensitive to scoring weight selection (see Sensitivity Analysis).}}{15}{table.1}\protected@file@percent }
\newlabel{tab:targets}{{1}{15}{\textbf {Top 10 AMR Drug Target Candidates}, ranked by composite score. FBA status indicates Tier A (lethal knockout confirmed) or Tier B (not mapped in GEM). Human homolog column reflects literature-curated audit. $^\dagger $Rankings are sensitive to scoring weight selection (see Sensitivity Analysis)}{table.1}{}}
